# Archived PHP under admin/_archive only (not used by server/ Node).
# Copy to .env in this folder or export in your shell before running legacy scripts.

LEGACY_MYSQL_HOST=localhost
LEGACY_MYSQL_USER=root
LEGACY_MYSQL_PASSWORD=
LEGACY_MYSQL_NAME=your_database_name

# admin/_archive/setup/setup.php — initial admin row (bcrypt); do not commit real values
LEGACY_SETUP_ADMIN_PASSWORD=

# admin/_archive/setup/migrate-add-role-column.php — one-time seed passwords for two users
LEGACY_MIGRATE_PASSWORD_USER1=
LEGACY_MIGRATE_PASSWORD_USER2=
